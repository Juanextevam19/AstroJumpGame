#:import NoTransition kivy.uix.screenmanager.NoTransition

ScreenManager:
    transition: NoTransition()
    MenuScreen:
    JuegoScreen:
<AjustesPopup>:
    title: ""
    separator_height: 0
    size_hint: (0.8, 0.5)
    background: ''
    background_color: (0, 0, 0, 0)

    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            # Efecto de cristal esmerilado
            Color:
                rgba: (0, 0.1, 0.2, 0.85)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]
            # Borde de neón para el popup
            Color:
                rgba: (0, 1, 1, 0.8)
            Line:
                width: 2
                rounded_rectangle: (self.x, self.y, self.width, self.height, 20)
        Label:
            text: "SISTEMAS"
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: dp(28)
            color: (0, 1, 1, 1)
            size_hint_y: 0.3

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            padding: [dp(20), 0]
            Label:
                text: "AUDIO"
                font_name: 'assets/Orbitron-Black.ttf'
                halign: 'left'
                text_size: self.size
            CheckBox:
                active: app.sonido_habilitado
                on_active: app.sonido_habilitado = self.active
                color: (0, 1, 1, 1)
                size_hint_x: None
                width: dp(50)

        Button:
            text: "REANUDAR"
            size_hint_y: None
            height: dp(60)
            on_release:
                root.juego.reanudar()
                root.dismiss()

        Button:
            text: "ABANDONAR"
            size_hint_y: None
            height: dp(60)
            background_color: (0.8, 0.2, 0.2, 0.2) # Toque rojo para salir
            on_release:
                root.dismiss()
                root.juego.ir_al_menu()
<MenuScreen>:
    name: 'menu'
    FloatLayout:
        canvas.before:
            Rectangle:
                source: 'assets/fondo_espacio.jpg'
                pos: self.pos
                size: self.size
            # Capa oscura para que el texto resalte
            Color:
                rgba: (0, 0, 0, 0.4)
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "ASTRO JUMP"
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: 70
            pos_hint: {'center_x': 0.5, 'center_y': 0.75}
            color: (0, 1, 1, 1)
            # Sombra de texto o brillo (simulado)
            canvas.before:
                Color:
                    rgba: (0, 1, 1, 0.2)
                Ellipse:
                    pos: self.center_x - 150, self.center_y - 50
                    size: 300, 100
        Button:
            text: "INICIAR MISIÓN"
            size_hint: (0.4, 0.1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.4}
            on_release: root.manager.current = 'juego'

<JuegoScreen>:
    name: 'juego'
    juego_widget: juego_id
    Juego:
        id: juego_id
        astronauta: astronauta_id
        Astronauta:
            id: astronauta_id
            pos: 100, 300
    Button:
        text: "PAUSA"
        size_hint: (None, None)
        size: (dp(120), dp(60))
        pos_hint: {'top': 0.98, 'right': 0.98}
        on_release:
            juego_id.pausar()
            root.abrir_popup_ajustes()

<Astronauta>:
    size: dp(40), dp(40)  # Tamaño visible en celular
    canvas:
        Rectangle:
            source: 'assets/nave.jpeg'
            pos: self.pos
            size: self.size

<Meteorito>:
    size: dp(70), dp(70)
    canvas:
        Rectangle:
            source: 'assets/meteorite_espacial.jpeg'
            pos: self.pos
            size: self.size

<Juego>:
    # Creamos una referencia para que Python lo encuentre
    label_cuenta_visual: contador_label

    canvas.before:
        Rectangle:
            source: 'assets/fondo_espacio.jpg'
            pos: self.pos
            size: self.size
    Label:
        id: contador_label
        text: ""  # Empieza vacío
        font_name: 'assets/Orbitron-Black.ttf'
        font_size: dp(30)
        top: root.top - dp(50) # Y aquí
        text: "Puntaje: " + str(root.puntaje)
        center: root.center
        color: (0, 1, 1, 1) # Cian neón
<Button>:
    font_name: 'assets/Orbitron-Black.ttf'
    background_normal: ''
    background_color: (0, 0, 0, 0) # Fondo transparente para usar el dibujo del canvas
    color: (0, 1, 1, 1) # Texto cian neón
    canvas.before:
        # Glow / Borde brillante
        Color:
            rgba: (0, 1, 1, 0.5)
        Line:
            width: 1.2
            rounded_rectangle: (self.x, self.y, self.width, self.height, 10)
        # Fondo sutil
        Color:
            rgba: (0.1, 0.1, 0.2, 0.6)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]

<GameOverPopup>:
    title: ""
    separator_height: 0
    size_hint: (0.8, 0.6)
    background: ''
    background_color: (0, 0, 0, 0)

    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 15
        canvas.before:
            Color:
                rgba: (0.2, 0, 0, 0.85) # Fondo rojo oscuro traslúcido
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]
            Color:
                rgba: (1, 0.2, 0.2, 0.8) # Borde rojo neón
            Line:
                width: 2
                rounded_rectangle: (self.x, self.y, self.width, self.height, 20)

        Label:
            text: "MISIÓN FALLIDA"
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: 32
            color: (1, 0.2, 0.2, 1)

        Label:
            text: "Puntaje Final: " + str(root.puntaje_final)
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: 24

        Button:
            text: "REINTENTAR"
            size_hint_y: None
            height: dp(60)
            on_release:
                root.juego.reiniciar_juego()
                root.dismiss()

        Button:
            text: "SALIR AL MENÚ"
            size_hint_y: None
            height: dp(60)
            on_release:
                root.dismiss()
                root.juego.ir_al_menu()
