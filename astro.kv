#:import NoTransition kivy.uix.screenmanager.NoTransition

ScreenManager:
    transition: NoTransition()
    MenuScreen:
    JuegoScreen:
<AjustesPopup>:
    title: ""
    separator_height: 0
    size_hint: (0.7, 0.5)
    background: ''
    background_color: (0, 0, 0, 0)

    BoxLayout:
        orientation: 'vertical'
        padding: 30
        spacing: 20
        canvas.before:
            # Efecto de cristal esmerilado
            Color:
                rgba: (0, 0.1, 0.2, 0.85)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]
            # Borde de neón para el popup
            Color:
                rgba: (0, 1, 1, 0.8)
            Line:
                width: 2
                rounded_rectangle: (self.x, self.y, self.width, self.height, 20)
        Label:
            text: "SISTEMAS"
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: 28
            color: (0, 1, 1, 1)

        BoxLayout:
            size_hint_y: None
            height: 50
            Label:
                text: "AUDIO"
                font_name: 'assets/Orbitron-Black.ttf'
            CheckBox:
                active: app.sonido_habilitado
                on_active: app.sonido_habilitado = self.active
                color: (0, 1, 1, 1)

        Button:
            text: "REANUDAR"
            size_hint_y: None
            height: 60
            on_release:
                root.juego.comenzar()
                root.dismiss()

        Button:
            text: "ABANDONAR"
            size_hint_y: None
            height: 60
            background_color: (0.8, 0.2, 0.2, 0.2) # Toque rojo para salir
            on_release:
                root.dismiss()
                root.juego.ir_al_menu()
<MenuScreen>:
    name: 'menu'
    FloatLayout:
        canvas.before:
            Rectangle:
                source: 'assets/fondo_espacio.jpg'
                pos: self.pos
                size: self.size
            # Capa oscura para que el texto resalte
            Color:
                rgba: (0, 0, 0, 0.4)
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "ASTRO JUMP"
            font_name: 'assets/Orbitron-Black.ttf'
            font_size: 70
            pos_hint: {'center_x': 0.5, 'center_y': 0.75}
            color: (0, 1, 1, 1)
            # Sombra de texto o brillo (simulado)
            canvas.before:
                Color:
                    rgba: (0, 1, 1, 0.2)
                Ellipse:
                    pos: self.center_x - 150, self.center_y - 50
                    size: 300, 100
        Button:
            text: "INICIAR MISIÓN"
            size_hint: (0.4, 0.1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.4}
            on_release: root.manager.current = 'juego'

<JuegoScreen>:
    name: 'juego'
    juego_widget: juego_id
    Juego:
        id: juego_id
        astronauta: astronauta_id
        Astronauta:
            id: astronauta_id
            pos: 100, 300
    Button:
        text: "PAUSA"
        size_hint: (None, None)
        size: (100, 50)
        pos_hint: {'top': 1, 'right': 1}
        on_release:
            juego_id.pausar()
            root.abrir_popup_ajustes()

<Astronauta>:
    size: dp(60), dp(60)  # Tamaño visible en celular
    canvas:
        Rectangle:
            source: 'assets/nave.jpeg'
            pos: self.pos
            size: self.size

<Meteorito>:
    size: dp(70), dp(70)
    canvas:
        Rectangle:
            source: 'assets/meteorite_espacial.jpeg'
            pos: self.pos
            size: self.size

<Juego>:
    canvas.before:
        Rectangle:
            source: 'assets/fondo_espacio.jpg'
            pos: self.pos
            size: self.size
    Label:
        font_size: 40
        center_x: root.width / 2
        top: root.top - 50
        text: "Puntaje: " + str(root.puntaje)
<Button>:
    font_name: 'assets/Orbitron-Black.ttf'
    background_normal: ''
    background_color: (0, 0, 0, 0) # Fondo transparente para usar el dibujo del canvas
    color: (0, 1, 1, 1) # Texto cian neón
    canvas.before:
        # Glow / Borde brillante
        Color:
            rgba: (0, 1, 1, 0.5)
        Line:
            width: 1.2
            rounded_rectangle: (self.x, self.y, self.width, self.height, 10)
        # Fondo sutil
        Color:
            rgba: (0.1, 0.1, 0.2, 0.6)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]